{
	"name": "celemas/cli",
	"description": "Celemas cli tools runner",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celemas.dev"
		}
	],
	"homepage": "https://celemas.dev/cli",
	"keywords": [
		"celemas",
		"cli"
	],
	"autoload": {
		"psr-4": {
			"Celemas\\Cli\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Celemas\\Cli\\Tests\\": "tests"
		}
	},
	"require": {
		"php": "^8.5"
	},
	"require-dev": {
		"celemas/dev": "^4.0"
	},
	"scripts": {
		"test": "./vendor/bin/phpunit --testdox --no-coverage --colors=always",
		"types": "./vendor/bin/psalm --no-cache",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"mdlint": "markdownlint-cli2 README.md CHANGELOG.md LICENSE.md docs/",
		"coverage": [
			"./vendor/bin/phpunit --testdox --path-coverage --coverage-text --coverage-php=.coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer .coverage/cover.php"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer types",
			"composer mdlint"
		]
	}
}
